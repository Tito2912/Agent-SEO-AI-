# NE PAS COMMITTER de .env réel (seulement un exemple)

# Netlify
NETLIFY_TOKEN=OK
NETLIFY_OAUTH_CLIENT_ID="netlify_oauth_client_id"

# Google APIs (GSC/GA4) via service account
GOOGLE_APPLICATION_CREDENTIALS="/chemin/vers/google-service-account.json"
GOOGLE_OAUTH_CLIENT_ID="google_oauth_client_id.apps.googleusercontent.com"
GOOGLE_OAUTH_CLIENT_SECRET="google_oauth_client_secret"
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:8000/oauth/google/callback"

# Exports CSV GSC (si tu n’utilises pas encore l’API)
GSC_QUERIES_CSV="/chemin/vers/gsc-queries.csv"
GSC_PAGES_CSV="/chemin/vers/gsc-pages.csv"

# Exports CSV Bing Webmaster Tools (si tu veux analyser Bing)
BING_QUERIES_CSV="/chemin/vers/bing-queries.csv"
BING_PAGES_CSV="/chemin/vers/bing-pages.csv"

# Bing Webmaster Tools API
BING_WEBMASTER_API_KEY=OK
BING_OAUTH_CLIENT_ID="bing_oauth_client_id"
BING_OAUTH_CLIENT_SECRET="bing_oauth_client_secret"
BING_OAUTH_REDIRECT_URI="http://localhost:8000/oauth/bing/callback"

# Git (si tu veux que l’agent clone/pousse automatiquement via HTTPS)
# Préférer un compte bot + token finement scopé, ou SSH.
GITHUB_TOKEN=OK
GITHUB_OAUTH_CLIENT_ID="github_oauth_client_id"
GITHUB_OAUTH_CLIENT_SECRET="github_oauth_client_secret"
GITHUB_OAUTH_REDIRECT_URI="http://localhost:8000/oauth/github/callback"

# OpenAI
OPENAI_API_KEY=OK
OPENAI_CHAT_MODEL="gpt-5.2"
IMAGE_ENABLED=true

# Google AI Studio (Gemini)
GOOGLE_GEMINI_API_KEY=OK
GOOGLE_GEMINI_IMAGE_MODEL="gemini-2.5-flash-image-preview"

# Assistant (chat dans la sidebar)
# Provider: auto (Gemini si configuré) | gemini | openai
SEO_AUDIT_ASSISTANT_PROVIDER=auto
SEO_AUDIT_ASSISTANT_OPENAI_MODEL="gpt-5.1-mini"
SEO_AUDIT_ASSISTANT_GEMINI_MODEL="gemini-2.0-flash-001"

# Google PageSpeed Insights API (runPagespeed)
PAGESPEED_API_KEY=OK

# Ahrefs API (v3) — utilisé par l’app SEO Agent (ex: synchro backlinks)
# 👉 Mets ta clé API ici (recommandé). Redémarre l’app après modification.
AHREFS_API_TOKEN="AHREFS_API_TOKEN_HERE"
# (legacy / compat) Ancien nom supporté par le code :
# cle_api="AHREFS_API_TOKEN_HERE"

# Ahrefs MCP (Model Context Protocol) — pour connecter Ahrefs à un client MCP (ChatGPT/Claude, etc.)
# ⚠️ Non utilisé par cette app web (sert uniquement aux clients MCP externes).
MCP_KEY="AHREFS_MCP_KEY_HERE"

# --- SaaS (web app) ---
# URL publique de l’app (Render) ou locale (dev)
PUBLIC_BASE_URL="http://localhost:8000"

# Clé de signature des sessions (générée automatiquement sur Render via render.yaml)
SEO_AGENT_SECRET_KEY="CHANGE_ME"

# Base de données (Render injecte DATABASE_URL)
# DATABASE_URL="postgresql://user:pass@host:5432/db"

# Signup gating (beta)
SIGNUP_INVITE_CODE="CHANGE_ME"
SIGNUP_DISABLED=false

# Stripe Billing (abonnements)
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ID_SOLO="price_..."
STRIPE_PRICE_ID_PRO="price_..."
STRIPE_PRICE_ID_BUSINESS="price_..."

# Worker / Jobs
# Désactive le worker interne si tu déploies un worker séparé.
SEO_AGENT_DISABLE_WORKER=false
SEO_AGENT_WORKER_CONCURRENCY=1
SEO_AGENT_CRAWL_JOB_TIMEOUT_SECONDS=21600
SEO_AGENT_AUTOPILOT_JOB_TIMEOUT_SECONDS=10800

# Retention (optionnel) — si 0/absent: pas de cleanup automatique
SEO_AGENT_JOBS_RETENTION_DAYS=0
SEO_AGENT_RUNS_RETENTION_DAYS=0

# Observabilité (optionnel)
SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_ENVIRONMENT="dev"
